# ============================================================
# Aimis Agent — 环境变量配置示例
# 复制此文件为 .env 后填入实际值
# ============================================================
# cp .env.example .env

# OpenAI API 配置（或其他兼容 API）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash

# 本地笔记目录（文件搜索的默认根路径）
NOTES_DIR=E:/agent办公室

# API 服务器端口（可选，默认 8765）
# AGENT_PORT=8765
