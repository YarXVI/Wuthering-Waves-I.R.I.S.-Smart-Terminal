{
  "name": "iris-desktop",
  "version": "0.2.0",
  "description": "辷ｱ蠑･譁?窶?陌壽供蜉槫ł螳､譯碁擇螳｢謌ｷ遶ｯ",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "electron:dev": "concurrently ¥"vite¥" ¥"wait-on http://localhost:5173 && electron .¥"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.1.0",
    "react-router-dom": "^6.20.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^4.1.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.iris.desktop",
    "productName": "辷ｱ蠑･譁?,
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "iris-portable-${version}.exe"
    }
  }
}
